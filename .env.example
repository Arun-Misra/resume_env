# ============================================================
# resume_env — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to git — it contains secrets.
# ============================================================

# ── LLM API ─────────────────────────────────────────────────

# OPTION A: Local Ollama (for development/testing — no token needed)
# Make sure Ollama is running: ollama serve
# Make sure model is pulled:  ollama pull gemma3:4b
API_BASE_URL=http://127.0.0.1:11434/v1
MODEL_NAME=gemma3:4b
HF_TOKEN=ollama

# OPTION B: HuggingFace router (for production submission)
# API_BASE_URL=https://router.huggingface.co/v1
# MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
# HF_TOKEN=hf_your_real_token_here

# ── Docker ──────────────────────────────────────────────────
# Must match the name used in: docker build -t resume_env .
IMAGE_NAME=resume_env

# ── Environment Server ───────────────────────────────────────
# SPACE_URL=https://arun-misra-resume-env.hf.space

# ── Optional Tuning ─────────────────────────────────────────
# MAX_STEPS=10
# TEMPERATURE=0.3
